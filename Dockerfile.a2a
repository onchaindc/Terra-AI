FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git bash \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g \
    @okxweb3/a2a-node@0.1.9 \
    @openai/codex@latest

RUN curl -fsSL https://raw.githubusercontent.com/okx/onchainos-skills/main/install.sh | sh \
    && install -m 0755 /root/.local/bin/onchainos /usr/local/bin/onchainos \
    && onchainos --version \
    && okx-a2a --version \
    && codex --version

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY . .

RUN node /app/scripts/patch-a2a-runtime.js

ENV NODE_ENV=production \
    HOME=/data/home \
    CODEX_HOME=/data/home/.codex \
    OKX_AGENT_TASK_HOME=/data/okx-agent-task \
    OKX_A2A_AI_PROVIDER=codex \
    OKX_A2A_AI_CODEX_COMMAND=/usr/local/bin/node \
    OKX_A2A_AI_CODEX_EXEC_ARGS_JSON='["/app/scripts/terra-a2a-responder.js","{prompt}"]' \
    OKX_A2A_AI_CODEX_RESUME_ARGS_JSON='["/app/scripts/terra-a2a-responder.js","{prompt}","{sessionId}"]' \
    OKX_A2A_AI_CWD=/app/cloud-a2a \
    OKX_A2A_AI_PROVIDER_TIMEOUT_MS=90000 \
    OKX_A2A_XMTP_WATCHDOG_INTERVAL_MS=60000 \
    OKX_A2A_XMTP_WATCHDOG_STALE_MS=300000

RUN mkdir -p /data/home /data/okx-agent-task \
    && ln -s /app/.agents /app/cloud-a2a/.agents \
    && chmod +x /app/scripts/start-a2a-railway.sh

CMD ["bash", "/app/scripts/start-a2a-railway.sh"]
