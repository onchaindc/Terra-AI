PORT=3000
NODE_ENV=production
DEFAULT_CURRENCY=USD
TERRA_SERVICE_NAME=Terra Compare
TERRA_SERVICE_URL=https://terra-ai.up.railway.app

# Live OKX.AI payment contract: 0.5 USDT per call on X Layer mainnet.
# Production must use okx mode. For unpaid local development only, explicitly
# override X402_MODE=off in a private local environment file.
X402_MODE=okx
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://www.okx.com
X402_PAY_TO_ADDRESS=0x9873dd140c12ecbfe9fcf70c16dc7b94b649e0b4
X402_NETWORK=eip155:196
X402_PRICE=$0.50
X402_SYNC_SETTLE=true
X402_MAX_TIMEOUT_SECONDS=300
X402_FACILITATOR_TIMEOUT_MS=15000
