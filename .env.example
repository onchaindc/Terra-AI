PORT=3000
NODE_ENV=development
DEFAULT_CURRENCY=USD
TERRA_SERVICE_NAME=Terra Compare
TERRA_SERVICE_URL=https://terra-ai.up.railway.app

# Payment modes:
# - demo: accepts requests for MVP testing and marks payment as unverified
# - okx: enforces real OKX x402 payment verification
# - off: disables payment checks
X402_MODE=off
X402_REQUIRE_HEADER=false
X402_PAYMENT_HEADER_NAME=x-terra-payment-proof

# Required only when X402_MODE=okx
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://www.okx.com
X402_PAY_TO_ADDRESS=
X402_NETWORK=eip155:196
X402_PRICE=$0.50
X402_SYNC_SETTLE=true
X402_MAX_TIMEOUT_SECONDS=300
